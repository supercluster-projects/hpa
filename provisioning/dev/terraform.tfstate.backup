               warn-version: latest\n                exemptions:\n                    namespaces:\n                        - kube-system\n                    runtimeClasses: []\n                    usernames: []\n                kind: PodSecurityConfiguration\n        auditPolicy:\n            apiVersion: audit.k8s.io/v1\n            kind: Policy\n            rules:\n                - level: Metadata\n    controllerManager:\n        image: registry.k8s.io/kube-controller-manager:v1.36.0\n    proxy:\n        image: registry.k8s.io/kube-proxy:v1.36.0\n    scheduler:\n        image: registry.k8s.io/kube-scheduler:v1.36.0\n    discovery:\n        enabled: true\n        registries:\n            kubernetes:\n                disabled: true\n            service: {}\n    etcd:\n        ca:\n            crt: \n            key: \n---\napiVersion: v1alpha1\nkind: HostnameConfig\nauto: stable\n","machine_secrets":{"certs":{"etcd":{"cert":"","key":""},"k8s":{"cert":"","key":""},"k8s_aggregator":{"cert":"","key":""},"k8s_serviceaccount":{"key":""},"os":{"cert":"","key":"LS0tLS1CRUdJTiBFRDI1NTE5IFBSSVZBVEUgS0VZLS0tLS0KTUM0Q0FRQXdCUVlESzJWd0JDSUVJTDBDc1g2Wm54Ykc4UWRVYmZpTUVnejQ2bmkxWVRucEVmVGc1SkZvWFVaRQotLS0tLUVORCBFRDI1NTE5IFBSSVZBVEUgS0VZLS0tLS0K"}},"cluster":{"id":"s4gY5EzzaVumZzrnDCTLNDJUDWhXfPD7ZF4rfbveiaM=","secret":"RGJ0H4CUo1uvhTMV7/yr/XvmKSk2W3XP5rxXVXPLRWk="},"secrets":{"aescbc_encryption_secret":null,"bootstrap_token":"dakaa5.d0bo4i2lh8uozgyn","secretbox_encryption_secret":"aelBmVWtISFTS6YmJFuytZemcpI+tE6sM7jivp2LeEE="},"trustdinfo":{"token":"hfpwch.qpomoq7n5g7qvfcb"}},"machine_type":"controlplane","talos_version":"v1.13"},"sensitive_attributes":[[{"type":"get_attr","value":"machine_secrets"},{"type":"get_attr","value":"certs"},{"type":"get_attr","value":"etcd"},{"type":"get_attr","value":"key"}],[{"type":"get_attr","value":"machine_secrets"},{"type":"get_attr","value":"certs"},{"type":"get_attr","value":"k8s"},{"type":"get_attr","value":"key"}],[{"type":"get_attr","valu