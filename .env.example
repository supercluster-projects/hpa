# ────────────────────────────────────────────────────────────────────
# HPA Dev Cluster — Environment Configuration
# ────────────────────────────────────────────────────────────────────
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# startup.sh sources .env automatically if present. CLI flags override
# env vars which override script defaults.
#
# Example:
#   ./startup.sh --envoy-ip 192.168.122.210
# ────────────────────────────────────────────────────────────────────

# ── Required (set your own) ─────────────────────────────────────────

# Git repo URL for the ArgoCD workload manifests (Kargo Warehouse images).
# Replace with your fork/repo:
GITOPS_REPO_URL=https://github.com/your-org/gitops-workloads.git

# Optional: Git revision/branch for the GitOps repo (default: main)
# GITOPS_REVISION=main


# ── Optional — secrets (auto-generated if unset) ───────────────────

# Harbor admin password (default: Harbor12345 — change for anything real)
# HARBOR_ADMIN_PASSWORD=your-harbor-password

# Infisical bootstrap secrets (openssl rand -hex 32 / -base64 16 / -hex 64
# are used if unset — these let you pin deterministic values across restarts)
# INFISICAL_ENCRYPTION_KEY=abcdef123456...
# INFISICAL_ADMIN_PASSWORD=your-infisical-admin-password
# INFISICAL_AUTH_SECRET=abcdef123456...


# ── Optional — paths ───────────────────────────────────────────────

# Path to kubeconfig (default: provisioning/tofu-libvirt-dev/kubeconfig)
# KUBECONFIG=/path/to/kubeconfig

# Envoy Gateway LoadBalancer IP (auto-detected if unset)
# ENVOY_IP=192.168.122.210


# ── Optional — registry / cluster internal URLs ────────────────────

# Harbor URL and project (defaults: cluster-internal svc)
# HARBOR_URL=http://harbor.harbor.svc.cluster.local
# HARBOR_PROJECT=hpa-workloads


# ── Optional — version overrides ───────────────────────────────────

# CILIUM_VERSION=1.16.5
# ROOK_VERSION=v1.16.4
# HARBOR_VERSION=2.12.2
# INFISICAL_VERSION=0.89.1
# CERT_MANAGER_VERSION=1.17.1
# KNATIVE_VERSION=1.16.0
# KEYDB_VERSION=x86_64_v6.3.3
# ENVOY_VERSION=1.2.2
# HEADLAMP_VERSION=0.16.0
# KARGO_VERSION=1.3.0
# ARGOCD_VERSION=7.8.0
# TALOS_VERSION=v1.9.5


# ── Optional — VM sizing (requires tofu re-apply) ──────────────────

# Number of VMs: control plane nodes and workers (default: 1 cp, 3 workers)
# TF_VAR_cp_count=1
# TF_VAR_worker_count=3

# vCPUs per VM (default: 2)
# TF_VAR_vm_cpu=2

# RAM per node in MB (default: cp=4096, worker=3072)
# TF_VAR_cp_ram_mb=4096
# TF_VAR_worker_ram_mb=3072

# Disk sizes in GB (default: os=20, ceph=20)
# TF_VAR_os_disk_size_gb=20
# TF_VAR_ceph_disk_size_gb=20

# Cluster network CIDR (default: 192.168.122.0/24)
# TF_VAR_cidr_block=192.168.122.0/24

# Talos version and image factory URL (default: v1.9.5)
# TF_VAR_talos_version=v1.9.5
