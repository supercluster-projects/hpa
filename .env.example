# ────────────────────────────────────────────────────────────────────
# HPA Dev Cluster — Environment Configuration
# ────────────────────────────────────────────────────────────────────
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# startup.sh sources .env automatically. Every provisioning script
# also sources preamble.sh which sources .env — all vars are
# available to every script. CLI flags override env vars.
#
# All variables below are REQUIRED unless marked [optional].
# ────────────────────────────────────────────────────────────────────

# ── Network (single source of truth — DEV_CIDR_BASE) ───────────────

# Base network prefix for all cluster IPs. Every other CIDR and IP
# derives from this single value — change it in one place.
DEV_CIDR_BASE=192.168.122

# Cluster network CIDR (derived from DEV_CIDR_BASE)
DEV_CIDR_BLOCK=${DEV_CIDR_BASE}.0/24

# Cilium LoadBalancer IP pool: last /28 of DEV_CIDR_BLOCK
# DEV_LB_POOL_CIDR=${DEV_CIDR_BASE}.208/28
DEV_LB_POOL_CIDR=${DEV_CIDR_BASE}.208/28

# Envoy Gateway LoadBalancer IP: 2nd usable in DEV_LB_POOL_CIDR (.208/28)
# DEV_ENVOY_IP=${DEV_CIDR_BASE}.210
DEV_ENVOY_IP=${DEV_CIDR_BASE}.210

# Libvirt bridge network name (default: hpa-bridge)
DEV_BRIDGE_NAME=hpa-bridge

# Gateway hostname
DEV_GATEWAY_NAME=hpa-dev-gateway


# ── Version pins (all required, no defaults) ───────────────────────

TALOS_VERSION=v1.13.5
CILIUM_VERSION=1.16.5
ROOK_VERSION=v1.16.4
CEPH_VERSION=v20.2.1
HARBOR_VERSION=2.12.2
INFISICAL_VERSION=0.89.1
CERT_MANAGER_VERSION=1.17.1
KNATIVE_VERSION=1.16.0
SPIN_OPERATOR_VERSION=v0.13.0
KEYDB_VERSION=x86_64_v6.3.3
ENVOY_VERSION=1.2.2
HEADLAMP_VERSION=0.16.0
KARGO_VERSION=1.3.0
ARGOCD_VERSION=7.8.0


# ── Secrets (all required — generate with openssl rand) ────────────

# Harbor admin password
HARBOR_ADMIN_PASSWORD=change-me-to-your-harbor-password

# Infisical bootstrap secrets (generate and save):
#   openssl rand -hex 32   -> INFISICAL_ENCRYPTION_KEY
#   openssl rand -base64 16 -> INFISICAL_ADMIN_PASSWORD
#   openssl rand -hex 64   -> INFISICAL_AUTH_SECRET
INFISICAL_ENCRYPTION_KEY=change-me-to-64-hex-chars
INFISICAL_ADMIN_PASSWORD=change-me-to-your-infisical-password
INFISICAL_AUTH_SECRET=change-me-to-128-hex-chars


# ── GitOps repo (required) ─────────────────────────────────────────

# Git repo URL for the ArgoCD workload manifests
GITOPS_REPO_URL=https://github.com/your-org/gitops-workloads.git

# Git revision/branch for the GitOps repo [optional, default: main]
DEV_GITOPS_REVISION=main


# ── Cluster naming ─────────────────────────────────────────────────

# Talos cluster name (default: hpa-dev)
DEV_CLUSTER_NAME=hpa-dev

# Node hostname prefix (default: hpa-node)
DEV_NODE_PREFIX=hpa-node

# Number of worker nodes (default: 3)
DEV_WORKER_COUNT=3

# Kubernetes namespace for workloads [optional, default: hpa-workloads]
DEV_WORKLOADS_NAMESPACE=hpa-workloads

# Kubernetes namespace for the HTTPRoute [optional, default: envoy-gateway-system]
DEV_GATEWAY_NAMESPACE=envoy-gateway-system

# HTTPRoute name for welcome route [optional, default: welcome-route]
DEV_HTTPROUTE_NAME=welcome-route


# ── Storage ────────────────────────────────────────────────────────

# StorageClass for KeyDB and Harbor PVCs (default: ceph-rbd)
DEV_STORAGE_CLASS=ceph-rbd


# ── Registry (internal cluster URLs) ──────────────────────────────

# Harbor internal service URL and project (defaults: cluster-internal svc)
DEV_HARBOR_URL=http://harbor.harbor.svc.cluster.local
DEV_HARBOR_PROJECT=hpa-workloads


# ── Paths [optional — have sensible defaults] ─────────────────────

# Path to kubeconfig (default: provisioning/tofu-libvirt-dev/kubeconfig)
# KUBECONFIG=/path/to/kubeconfig

# Kustomize overlay path for workloads (required — relative to provisioning/scripts/)
DEV_GITOPS_OVERLAY_PATH=../../gitops-workloads/functions/overlays/dev


# ── VM sizing (OpenTofu — requires tofu re-apply) [optional] ──────

# TF_VAR_DEV_CP_COUNT=1
# TF_VAR_DEV_WORKER_COUNT=3
# TF_VAR_DEV_VM_CPU=2
# TF_VAR_DEV_CP_RAM_MB=4096
# TF_VAR_DEV_WORKER_RAM_MB=3072
# TF_VAR_DEV_OS_DISK_SIZE_GB=20
# TF_VAR_DEV_CEPH_DISK_SIZE_GB=20


# ── Talos image factory URL [optional, default: official] ──────────

# TF_VAR_DEV_TALOS_IMAGE_FACTORY_URL=https://factory.talos.dev/image
